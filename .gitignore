.DS_Store
.env
.pytest_cache/
.ruff_cache/
.run/
.workbuddy/
__pycache__/
*.pyc
node_modules/
dist/
build/
*.tsbuildinfo
.venv/
.data/
agent_tasks/
*.egg-info/
artifacts/execution_bundles/
dev/
live/*
!live/.gitkeep

# Private production signal engines and paired strategies stay local-only.
apps/worker/src/quant_terminal_worker/signal_engines/*.py
!apps/worker/src/quant_terminal_worker/signal_engines/__init__.py
!apps/worker/src/quant_terminal_worker/signal_engines/runtime.py
!apps/worker/src/quant_terminal_worker/signal_engines/liquidity_sweep_v1.py
packages/strategy_modules/src/quant_terminal_strategies/*.py
!packages/strategy_modules/src/quant_terminal_strategies/__init__.py
!packages/strategy_modules/src/quant_terminal_strategies/liquidity_sweep_v1_base.py
artifacts/signal_engine/scripts/**/*.py
artifacts/signal_engine/src/vegas/*.py
!artifacts/signal_engine/src/vegas/__init__.py
artifacts/signal_engine/tests/*.py
